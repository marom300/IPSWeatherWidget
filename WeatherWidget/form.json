{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "Auto-Erkennung (OpenWeather / WeatherUnderground)",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "Optional: Wetter-Instanz auswählen und Variablen automatisch erkennen. Funktioniert mit OpenWeatherOneCall und WeatherUnderground. Für andere Wetter-Module die Variablen unten manuell zuweisen."
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "SelectInstance",
                            "name": "SourceInstance",
                            "caption": "Wetter-Instanz",
                            "width": "400px"
                        },
                        {
                            "type": "Select",
                            "name": "StartDay",
                            "caption": "Beginne ab",
                            "width": "200px",
                            "options": [
                                { "caption": "Heute (D0)", "value": 0 },
                                { "caption": "Morgen (D1)", "value": 1 }
                            ]
                        }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "Variablen automatisch erkennen & zuweisen",
                            "onClick": "echo WTR_AutoConfigure($id);"
                        },
                        {
                            "type": "Button",
                            "caption": "Idents der Instanz anzeigen (Diagnose)",
                            "onClick": "echo WTR_ScanIdents($id);"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Allgemein",
            "expanded": true,
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "DayCount",
                    "caption": "Anzahl Vorhersage-Tage",
                    "minimum": 1,
                    "maximum": 7,
                    "suffix": "Tage"
                },
                {
                    "type": "NumberSpinner",
                    "name": "UpdateInterval",
                    "caption": "Update-Intervall",
                    "minimum": 1,
                    "maximum": 60,
                    "suffix": "Minuten"
                },
                {
                    "type": "CheckBox",
                    "name": "ShowRain",
                    "caption": "Niederschlag anzeigen"
                },
                {
                    "type": "CheckBox",
                    "name": "ShowWind",
                    "caption": "Wind anzeigen"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Darstellung",
