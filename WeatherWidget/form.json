{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "🔍 Auto-Erkennung (OpenWeather)",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "Wähle deine OpenWeatherOneCall-Instanz aus und klicke 'Variablen erkennen'. Alle Felder werden automatisch befüllt."
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "SelectInstance",
                            "name": "SourceInstance",
                            "caption": "OpenWeather-Instanz",
                            "width": "400px"
                        },
                        {
                            "type": "Select",
                            "name": "StartDay",
                            "caption": "Beginne ab",
                            "width": "200px",
                            "options": [
                                { "caption": "Heute (D0)", "value": 0 },
                                { "caption": "Morgen (D1)", "value": 1 }
                            ]
                        }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "🚀 Variablen automatisch erkennen & zuweisen",
                            "onClick": "echo WTR_AutoConfigure($id);"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Allgemein",
            "expanded": true,
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "DayCount",
                    "caption": "Anzahl Vorhersage-Tage",
                    "minimum": 1,
                    "maximum": 7,
                    "suffix": "Tage"
                },
                {
                    "type": "NumberSpinner",
                    "name": "UpdateInterval",
                    "caption": "Update-Intervall",
                    "minimum": 1,
                    "maximum": 60,
                    "suffix": "Minuten"
                },
                {
                    "type": "CheckBox",
                    "name": "ShowRain",
                    "caption": "Niederschlag anzeigen"
                },
                {
                    "type": "CheckBox",
                    "name": "ShowWind",
                    "caption": "Wind anzeigen"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Balken-Darstellung",
            "expanded": false,
            "items": [
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "NumberSpinner",
                            "name": "RainBarHeight",
                            "caption": "Regenbalken Höhe (px)",
                            "minimum": 10,
                            "maximum": 100,
                            "suffix": "px"
                        },
                        {
                            "type": "NumberSpinner",
                            "name": "RainBarWidth",
                            "caption": "Regenbalken Breite (%)",
                            "minimum": 20,
                            "maximum": 100,
                            "suffix": "%"
                        }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "NumberSpinner",
                            "name": "WindBarHeight",
                            "caption": "Windbalken Höhe (px)",
                            "minimum": 10,
                            "maximum": 100,
                            "suffix": "px"
                        },
                        {
                            "type": "NumberSpinner",
                            "name": "WindBarWidth",
                            "caption": "Windbalken Breite (%)",
                            "minimum": 20,
                            "maximum": 100,
                            "suffix": "%"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Variablen-Zuordnung (manuell)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Diese Felder werden von der Auto-Erkennung automatisch befüllt. Manuelle Änderung nur bei Bedarf."
